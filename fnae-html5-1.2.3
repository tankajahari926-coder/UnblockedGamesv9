<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Five Nights at Epsteins</title>
    <style>
        /* This makes the game fill the entire iframe */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #000; /* Black background for horror games */
        }

        #canvas-container {
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        canvas {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
    </style>
</head>
<body>

    <div id="canvas-container">
        <!-- Most HTML5 games use a Canvas element. 
             The ID 'canvas' is standard for many engines (Construct, Phaser, etc.) -->
        <canvas id="canvas" oncontextmenu="event.preventDefault()"></canvas>
    </div>

    <!-- This is where the game engine loads. 
         If your game has a different main .js file name, change 'game.js' below -->
    <script src="game.js"></script>

    <script>
        // Automatic focus to ensure keyboard controls work immediately
        window.onload = function() {
            window.focus();
            document.getElementById('canvas').focus();
        };
    </script>
</body>
</html>
